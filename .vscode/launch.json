{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "main_jit",
            "type": "debugpy",
            "request": "launch",
            "program": "src/main_jit.py",
            "console": "integratedTerminal",
            "env": {
                "CUDA_VISIBLE_DEVICES": "1"
            },
            "args": [
                "--model",
                "JiT_ParaCond-H/16",
                "--proj_dropout",
                "0.0",
                "--P_mean",
                "-0.8",
                "--P_std",
                "0.8",
                "--noise_scale",
                "1.0",
                "--batch_size",
                "1",
                "--blr",
                "5e-5",
                "--epochs",
                "50000",
                "--warmup_epochs",
                "30",
                "--data_path",
                "data/MoNuSeg/",
                "--dataset",
                "MoNuSeg",
                "--img_channel",
                "3",
                "--mask_channel",
                "1",
                "--img_size",
                "256",
                // "--online_eval",
                "--resume",
                "checkpoint-5000.pth",
                "--add_loss",
                "--add_loss_name",
                "dice_bce",
                // "--cond_weight",
                // "{'cond': 'learnable', 'low_cond': 'learnable', 'high_cond': 'learnable'}"
            ]
        },
        {
            "name": "inference_jit",
            "type": "debugpy",
            "request": "launch",
            "program": "src/inference_jit.py",
            "console": "integratedTerminal",
            "env": {
                "CUDA_VISIBLE_DEVICES": "0"
            },
            "args": [
                "--model",
                "JiT_ParaCondWaveFix-H/16",
                "--checkpoint",
                "checkpoint-3000.pth",
                "--data_path",
                "data/OCTA500_6M/test",
                "--dataset",
                "OCTA500_6M",
                "--output_dir",
                "outputs",
                "--batch_size",
                "1",
                "--num_workers",
                "0",
                "--img_size",
                "256",
                "--img_channel",
                "1",
                "--mask_channel",
                "1",
                "--samp_patch_size",
                "256",
                "--stride",
                "256",
                "--metrics",
            ],
        }
    ]
}