{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "main_jit",
            "type": "debugpy",
            "request": "launch",
            "module": "torch.distributed.run",
            "console": "integratedTerminal",
            "env": {
                "CUDA_VISIBLE_DEVICES": "3"
            },
            "args": [
                "--nproc_per_node=1",
                "--nnodes=1",
                "--node_rank=0",
                "--master_port=29502",
                "${workspaceFolder}/src/main_jit.py",
                "--model",
                "JiT-B/16",
                "--proj_dropout",
                "0.0",
                "--P_mean",
                "-0.8",
                "--P_std",
                "0.8",
                "--img_size",
                "256",
                "--noise_scale",
                "1.0",
                "--batch_size",
                "64",
                "--blr",
                "5e-5",
                "--epochs",
                "10000",
                "--warmup_epochs",
                "5",
                "--data_path",
                "data/OCTA500_6M/",
                "--dataset",
                "OCTA500_6M",
                "--img_channel",
                "1",
                "--mask_channel",
                "1"
            ]
        },
        {
            "name": "inference_jit",
            "type": "debugpy",
            "request": "launch",
            "program": "src/inference_jit.py",
            "console": "integratedTerminal",
            "env": {
                "CUDA_VISIBLE_DEVICES": "3"
            },
            "args": [
                "--checkpoint",
                "checkpoint-1000.pth",
                "--data_path",
                "data/OCTA500_6M/test",
                "--output_dir",
                "outputs",
                "--batch_size",
                "4",
                "--num_workers",
                "0",
                "--img_size",
                "256",
                "--img_channel",
                "1",
                "--mask_channel",
                "1",
                "--patch_size",
                "256",
                "--stride",
                "128",
                "--metrics",
            ],
        }
    ]
}